{
  "name": "reef-search",
  "version": "0.3.3",
  "description": "Fuzzy, keyboard-first search for static sites. No backend, no build step, no account. Works across web pages, and indexes links as well for navigation.",
  "keywords": [
    "js",
    "static",
    "search"
  ],
  "homepage": "https://github.com/somalip/Reef#readme",
  "bugs": {
    "url": "https://github.com/somalip/Reef/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somalip/Reef.git"
  },
  "license": "MIT",
  "author": "Pranav Somalinga",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./dist/reef.min.js": "./dist/reef.min.js"
  },
  "files": [
    "index.ts",
    "src"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "esbuild src/browser.ts --bundle --format=iife --global-name=ReefSearch --outfile=dist/reef.min.js --minify",
    "test": "node --import tsx --test"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "esbuild-wasm": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
