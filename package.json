{
  "name": "reef-search",
  "version": "0.3.4",
  "description": "Fuzzy, keyboard-first search for static sites. No backend, no build step, no account. Works across web pages, and indexes links as well for navigation.",
  "keywords": [
    "js",
    "static",
    "search"
  ],
  "homepage": "https://github.com/somalip/Reef#readme",
  "bugs": {
    "url": "https://github.com/somalip/Reef/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somalip/Reef.git"
  },
  "license": "MIT",
  "author": "Pranav Somalinga",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./dist/reef.min.js": "./dist/reef.min.js",
    "./dist/reef-agent-ready.js": "./dist/reef-agent-ready.js",
    "./dist/reef-agent-ready.min.js": "./dist/reef-agent-ready.min.js",
    "./agent-ready": {
      "import": "./src/agent-ready.ts",
      "types": "./src/agent-ready.ts"
    }
  },
  "files": [
    "index.ts",
    "src",
    "dist",
    "scripts"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "esbuild src/browser.ts --bundle --format=iife --global-name=ReefSearch --outfile=dist/reef.min.js --minify --sourcemap && npm run build:agent-ready",
    "build:agent-ready": "esbuild src/agent-ready-entry.ts --bundle --format=iife --global-name=ReefAgentReady --outfile=dist/reef-agent-ready.js --sourcemap && esbuild src/agent-ready-entry.ts --bundle --format=iife --global-name=ReefAgentReady --outfile=dist/reef-agent-ready.min.js --minify --sourcemap",
    "export-manifest": "node scripts/export-agent-manifest.mjs",
    "build:extension": "node plugin/build.mjs",
    "dev:extension": "node plugin/build.mjs --watch",
    "test:extension": "node --import tsx --test plugin/tests/extension-contracts.test.mjs",
    "test": "node --import tsx --test"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.28.1",
    "esbuild-wasm": "^0.28.1",
    "play-dl": "^1.9.7",
    "playwright": "^1.61.1",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2",
    "webextension-polyfill": "^0.12.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
