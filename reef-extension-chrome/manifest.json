{
  "manifest_version": 3,
  "name": "Reef for Browsers",
  "version": "0.1.0",
  "default_locale": "en",
  "description": "__MSG_appDescription__",
  "icons": {
    "16": "icons/plugin_logo.png",
    "32": "icons/plugin_logo.png",
    "48": "icons/plugin_logo.png",
    "128": "icons/plugin_logo.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icons/plugin_logo.png",
    "32": "icons/plugin_logo.png",
    "48": "icons/plugin_logo.png",
    "128": "icons/plugin_logo.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/reef.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "contextMenus",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "omnibox": {
    "keyword": "reef"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "Open Reef for Browsers popup"
    },
    "open-spotlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "MacCtrl+Shift+L"
      },
      "description": "Open Reef Spotlight (search across all tabs)"
    }
  }
}
