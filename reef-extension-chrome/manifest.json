{
  "manifest_version": 3,
  "name": "Reef for Browsers",
  "version": "0.1.0",
  "default_locale": "en",
  "description": "__MSG_appDescription__",
  "icons": {
    "16": "icons/plugin_logo.png",
    "32": "icons/plugin_logo.png",
    "48": "icons/plugin_logo.png",
    "128": "icons/plugin_logo.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icons/plugin_logo.png",
    "32": "icons/plugin_logo.png",
    "48": "icons/plugin_logo.png",
    "128": "icons/plugin_logo.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "contextMenus",
    "unlimitedStorage",
    "bookmarks",
    "history",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "omnibox": {
    "keyword": "reef"
  },
  "commands": {
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Reef for Browsers popup (Cmd/Ctrl+Shift+K)"
    },
    "open-spotlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Reef Spotlight (search across all tabs)"
    }
  }
}
